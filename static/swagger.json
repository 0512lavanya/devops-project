{
  "openapi": "3.0.0",
  "info": {
    "title": "VitalDrop API",
    "version": "1.0.0",
    "description": "JWT-secured APIs for VitalDrop advanced features."
  },
  "paths": {
    "/api/v1/auth/login": {
      "post": {
        "summary": "Authenticate user",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "username": { "type": "string" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Returns JWT token" },
          "401": { "description": "Invalid credentials" }
        }
      }
    },
    "/api/v1/match/{request_id}": {
      "get": {
        "summary": "Smart Match Donors",
        "security": [{"BearerAuth": []}],
        "parameters": [
          { "name": "request_id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Matching donors" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  }
}
